APP_NAME=Leanbox
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# PostgreSQL via Supabase. Use the SESSION pooler (port 5432) for the persistent app.
DB_CONNECTION=pgsql
DB_HOST=
DB_PORT=5432
DB_DATABASE=postgres
DB_USERNAME=
DB_PASSWORD=

# Optional local-dev PDO tuning for a remote DB (both default off; leave unset in prod).
# DB_PERSISTENT: reuse the DB connection across requests (skips per-request TLS handshake).
# DB_EMULATE_PREPARES: send queries as a single round trip instead of prepare+execute.
# Safe with the Supabase session pooler (port 5432); do NOT use with a transaction pooler (6543).
DB_PERSISTENT=false
DB_EMULATE_PREPARES=false

# Supabase Storage (S3-compatible) for product/uploaded images. Bucket: leanbox-images.
SUPABASE_ENDPOINT=
SUPABASE_ACCESS_KEY=
SUPABASE_SECRET_KEY=
SUPABASE_REGION=
SUPABASE_BUCKET=leanbox-images
SUPABASE_PUBLIC_URL=

# Next.js frontend origin(s) for CORS. Comma-separate multiple.
FRONTEND_URL=http://localhost:3000

# No Redis: cache, queue, and sessions run on the database driver.
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"
